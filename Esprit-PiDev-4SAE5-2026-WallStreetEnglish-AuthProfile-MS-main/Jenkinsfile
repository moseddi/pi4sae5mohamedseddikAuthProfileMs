pipeline {
    agent any

    environment {
        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_TOKEN    = credentials('jenkins-user')

        AUTH_IMAGE  = 'wallstreet/auth-service'
        USER_IMAGE  = 'wallstreet/user-management-service'
        IMAGE_TAG   = "${env.BUILD_NUMBER}"

        ROOT = 'Esprit-PiDev-4SAE5-2026-WallStreetEnglish-AuthProfile-MS-main'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Parent POM') {
            steps {
                dir("${ROOT}") {
                    sh 'mvn clean install -N -B'
                }
                echo "✅ Parent POM installé"
            }
        }

        stage('Tests - Auth Service') {
            steps {
                dir("${ROOT}/microservices/auth-service") {
                    sh 'mvn clean verify -B'
                }
                echo "✅ Tests Auth Service passés"
            }
            post {
                always {
                    junit(
                        testResults: "${ROOT}/microservices/auth-service/target/surefire-reports/*.xml",
                        allowEmptyResults: true
                    )
                }
            }
        }

        stage('Tests - User Service') {
            steps {
                dir("${ROOT}/microservices/user-management-service") {
                    sh 'mvn clean verify -B'
                }
                echo "✅ Tests User Service passés"
            }
            post {
                always {
                    junit(
                        testResults: "${ROOT}/microservices/user-management-service/target/surefire-reports/*.xml",
                        allowEmptyResults: true
                    )
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sq1') {
                    dir("${ROOT}/microservices/auth-service") {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=auth-service \
                                -Dsonar.projectName="Auth Service" \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                    dir("${ROOT}/microservices/user-management-service") {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=user-service \
                                -Dsonar.projectName="User Management Service" \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
                echo "✅ Analyse SonarQube terminée"
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "✅ Quality Gate passé"
            }
        }

        stage('Build Docker Images') {
            steps {
                echo "🐳 Construction des images Docker..."
                dir("${ROOT}") {
                    // auth-service: Maven build happens inside Docker (works fine)
                    sh "docker build -t ${AUTH_IMAGE}:${IMAGE_TAG} -t ${AUTH_IMAGE}:latest -f microservices/auth-service/Dockerfile ."

                    // user-management-service: jar already built by mvn verify above
                    // Docker just copies the jar (no Maven inside Docker)
                    sh "docker build -t ${USER_IMAGE}:${IMAGE_TAG} -t ${USER_IMAGE}:latest -f microservices/user-management-service/Dockerfile ."
                }
                echo "✅ Images construites"
            }
        }

        stage('Deploy - Start Containers') {
            steps {
                echo "🚀 Déploiement de tous les conteneurs..."
                dir("${ROOT}") {
                    sh 'docker compose down --remove-orphans || true'
                    sh 'docker compose up -d'
                }
                echo "✅ Tous les conteneurs démarrés"
            }
        }

        stage('Smoke Test') {
            steps {
                echo "⏳ Attente du démarrage (45s)..."
                sh 'sleep 45'
                sh """
                    curl --fail --silent http://localhost:8761/actuator/health \
                    | grep -q '"status":"UP"' \
                    && echo "✅ Eureka UP" \
                    || (echo "❌ Eureka DOWN" && exit 1)
                """
                sh """
                    curl --fail --silent http://localhost:8081/actuator/health \
                    | grep -q '"status":"UP"' \
                    && echo "✅ Auth Service UP" \
                    || (echo "❌ Auth Service DOWN" && exit 1)
                """
                sh """
                    curl --fail --silent http://localhost:8082/actuator/health \
                    | grep -q '"status":"UP"' \
                    && echo "✅ User Service UP" \
                    || (echo "❌ User Service DOWN" && exit 1)
                """
                sh """
                    curl --fail --silent http://localhost:8089/actuator/health \
                    | grep -q '"status":"UP"' \
                    && echo "✅ API Gateway UP" \
                    || (echo "❌ API Gateway DOWN" && exit 1)
                """
            }
        }
    }

    post {
        success {
            echo "🎉 Pipeline CI/CD terminé avec succès!"
            echo "📊 SonarQube  : ${SONAR_HOST_URL}"
            echo "🔐 Keycloak   : http://localhost:6083"
            echo "🐰 RabbitMQ   : http://localhost:15672"
            echo "📡 Eureka     : http://localhost:8761"
            echo "🐳 Auth       : http://localhost:8081"
            echo "🐳 User       : http://localhost:8082"
            echo "🌐 Gateway    : http://localhost:8089"
        }
        failure {
            echo "❌ Pipeline échoué"
            dir("${ROOT}") {
                sh 'docker compose down || true'
            }
        }
    }
}