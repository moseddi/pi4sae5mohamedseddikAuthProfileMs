pipeline {
    agent any

    environment {
        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_TOKEN    = credentials('jenkins-user')

        AUTH_IMAGE  = 'wallstreet/auth-service'
        USER_IMAGE  = 'wallstreet/user-management-service'
        IMAGE_TAG   = "${env.BUILD_NUMBER}"

        // Folder that contains docker-compose.yml, microservices/, keycloak/, mysql/
        ROOT = 'Esprit-PiDev-4SAE5-2026-WallStreetEnglish-AuthProfile-MS-main'
    }

    stages {

        // ─────────────────────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('Install Parent POM') {
            steps {
                dir("${ROOT}") {
                    sh 'mvn clean install -N -B'
                }
                echo "✅ Parent POM installé"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        // mvn verify → builds JAR + runs tests + generates JaCoCo report
        // The JAR in target/ is copied by Dockerfile (no Maven inside Docker)
        stage('Tests - Auth Service') {
            steps {
                dir("${ROOT}/microservices/auth-service") {
                    sh 'mvn clean verify -B'
                }
                echo "✅ Tests Auth Service passés"
            }
            post {
                always {
                    junit(
                        testResults: "${ROOT}/microservices/auth-service/target/surefire-reports/*.xml",
                        allowEmptyResults: true
                    )
                }
            }
        }

        stage('Tests - User Service') {
            steps {
                dir("${ROOT}/microservices/user-management-service") {
                    sh 'mvn clean verify -B'
                }
                echo "✅ Tests User Service passés"
            }
            post {
                always {
                    junit(
                        testResults: "${ROOT}/microservices/user-management-service/target/surefire-reports/*.xml",
                        allowEmptyResults: true
                    )
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sq1') {
                    dir("${ROOT}/microservices/auth-service") {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=auth-service \
                                -Dsonar.projectName="Auth Service" \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                    dir("${ROOT}/microservices/user-management-service") {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=user-service \
                                -Dsonar.projectName="User Management Service" \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
                echo "✅ Analyse SonarQube terminée"
            }
        }



        // ─────────────────────────────────────────────────────────────────────
        // JARs already built by mvn verify → Docker just COPY them = FAST build
        stage('Build Docker Images') {
            steps {
                echo "🐳 Construction des images Docker..."
                dir("${ROOT}") {
                    // Build both images; tag with build number AND latest
                    sh "docker build \
                            -t ${AUTH_IMAGE}:${IMAGE_TAG} \
                            -t ${AUTH_IMAGE}:latest \
                            -f microservices/auth-service/Dockerfile \
                            microservices/auth-service"

                    sh "docker build \
                            -t ${USER_IMAGE}:${IMAGE_TAG} \
                            -t ${USER_IMAGE}:latest \
                            -f microservices/user-management-service/Dockerfile \
                            microservices/user-management-service"
                }
                echo "✅ Images construites : ${AUTH_IMAGE}:${IMAGE_TAG} | ${USER_IMAGE}:${IMAGE_TAG}"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        // DEPLOY
        //   • Stop only containers (--remove-orphans) — volumes are KEPT so
        //     MySQL data and Keycloak realm config survive between builds.
        //   • Start everything defined in docker-compose.yml:
        //       mysql, keycloak, rabbitmq, eureka,
        //       auth-service, user-service, api-gateway
        stage('Deploy - Start Containers') {
            steps {
                echo "🚀 Déploiement de tous les conteneurs..."
                dir("${ROOT}") {
                    // Stop containers only — do NOT wipe volumes (--volumes would
                    // delete MySQL data and Keycloak realm on every build)
                    sh 'docker compose down --remove-orphans || true'

                    // Pull any updated base images (mysql, keycloak, rabbitmq…)
                    sh 'docker compose pull --ignore-pull-failures || true'

                    // Start ALL services defined in docker-compose.yml
                    sh 'docker compose up -d'
                }
                echo "✅ Tous les conteneurs lancés"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        // SMOKE TEST
        //   Keycloak alone can take 60-90s on first start (realm import).
        //   We wait up to 3 minutes total, polling every 10s, before failing.
        stage('Smoke Test') {
            steps {
                echo "⏳ Attente du démarrage des services (90s minimum pour Keycloak)..."
                sh 'sleep 90'

                // Helper: poll a URL until it returns {"status":"UP"} or timeout
                script {
                    def waitForService = { String name, String url, int retries ->
                        for (int i = 0; i < retries; i++) {
                            def status = sh(
                                script: "curl --silent --max-time 5 ${url} | grep -c '\"status\":\"UP\"' || true",
                                returnStdout: true
                            ).trim()
                            if (status == '1') {
                                echo "✅ ${name} UP"
                                return
                            }
                            echo "⏳ ${name} pas encore prêt (tentative ${i+1}/${retries})..."
                            sh 'sleep 10'
                        }
                        error("❌ ${name} n'a pas démarré après ${retries * 10}s")
                    }

                    // Infrastructure checks
                    waitForService('Eureka',       'http://localhost:8761/actuator/health',  12)
                    waitForService('Keycloak',     'http://localhost:6083/health/ready',     18)
                    waitForService('RabbitMQ',     'http://localhost:15672/api/healthchecks/node', 12)

                    // Application checks
                    waitForService('Auth Service', 'http://localhost:8081/actuator/health',  12)
                    waitForService('User Service', 'http://localhost:8082/actuator/health',  12)
                    waitForService('API Gateway',  'http://localhost:8089/actuator/health',  12)
                }
            }
        }

    } // end stages

    // ─────────────────────────────────────────────────────────────────────────
    post {
        success {
            echo """
🎉 Pipeline CI/CD terminé avec succès! Build #${env.BUILD_NUMBER}

📊 SonarQube  : ${SONAR_HOST_URL}
🔐 Keycloak   : http://localhost:6083
🐰 RabbitMQ   : http://localhost:15672
📡 Eureka     : http://localhost:8761
🐳 Auth       : http://localhost:8081
🐳 User       : http://localhost:8082
🌐 Gateway    : http://localhost:8089

Images déployées :
  ${AUTH_IMAGE}:${IMAGE_TAG}
  ${USER_IMAGE}:${IMAGE_TAG}
"""
        }

        failure {
            echo "❌ Pipeline échoué — arrêt des conteneurs applicatifs (les infra restent actifs)"
            dir("${ROOT}") {
                // Only stop the application containers on failure,
                // keep mysql/keycloak/rabbitmq running to preserve data
                sh 'docker compose stop auth-service user-service api-gateway || true'
            }
        }

        always {
            // Print container status for debugging
            sh 'docker compose -f ${ROOT}/docker-compose.yml ps || true'
        }
    }
}